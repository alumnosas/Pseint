Algoritmo ejercicio_8
	Definir temp_in Como Real
	Definir llueve_in Como Logico
	
	Escribir "Dime la temperatura"
	Leer temp_in
	Escribir "Dime si llueve verdadero/falso"
	Leer llueve_in
	
	Si temp_in < 25 y llueve_in Entonces
		Escribir "Ponerse ropa de abrigo"
	SiNo
		Escribir "ponerse ropa corta"
	FinSi
FinAlgoritmo
